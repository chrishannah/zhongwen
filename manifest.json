{
  "manifest_version": 3,
  "name": "Zhongwen",
  "version": "1.0.0",
  "description": "Learn Mandarin Chinese, one new tab at a time. Shows a random character with pinyin, phonetics, and meaning.",
  "permissions": ["storage"],
  "optional_host_permissions": ["https://api.unsplash.com/*", "https://images.unsplash.com/*"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
